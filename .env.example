NODE_ENV=development
PORT=3000
API_MODE=enterprise

# Supabase pooled postgres URL (recommended in production)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres?sslmode=require

# Optional local DB fallback
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=backend_saas
DB_SSL=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=7d
JWT_REFRESH_TTL=7d
LOG_LEVEL=info
# Slot grid + create diagnostics — filter server logs with "BookingProcess". Set false in production.
BOOKING_PROCESS_LOG=true
# Copy to ".env" and fill in real values. Never commit ".env".
# Migrations: `npm run migration:run` loads ".env" from this folder (see scripts/run-migrations.cjs).

# --- Supabase (browser / dashboard clients) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_jwt
# Optional newer keys (if your Supabase project uses them)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# --- Postgres connection strings (Supabase: Settings → Database) ---
# Session / direct (port 5432): best for TypeORM migrations and DDL.
POSTGRES_URL_NON_POOLING=postgres://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# Transaction pooler (port 6543): common for serverless / pooled API traffic.
POSTGRES_URL=postgres://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
# Some tools (e.g. Prisma) use this name; same pooler URL as above if applicable.
POSTGRES_PRISMA_URL=postgres://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# --- Postgres discrete vars (optional; used if URLs are not set) ---
POSTGRES_HOST=db.YOUR_PROJECT_REF.supabase.co
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_database_password
POSTGRES_DATABASE=postgres

# --- Supabase server / Auth (API only; never expose to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_jwt
SUPABASE_JWT_SECRET=your_jwt_signing_secret
SUPABASE_SECRET_KEY=sb_secret_your_key

# --- OpenAPI / Swagger UI (/api-docs and /api-docs-json by default) ---
# Omit or true: docs enabled. Set ENABLE_SWAGGER=false to hide docs (e.g. public production).

# --- Nest / TypeORM ---
# When unset: migrations run on startup only if NODE_ENV=production.
# Set to "true" or "false" to force on or off.
# RUN_STARTUP_MIGRATIONS=

# --- Password reset (POST /auth/forgot-password, /auth/reset-password) ---
# Token lifetime in minutes (default 60, max 1440).
# PASSWORD_RESET_EXPIRES_MINUTES=60
# Dev/Postman only: include raw resetToken in forgot-password JSON. Never use in production.
# AUTH_PASSWORD_RESET_RETURN_TOKEN=false

# --- Payment Gateways (Sandbox Defaults) ---
EASYPAISA_STORE_ID="12345"
EASYPAISA_HASH_KEY="default_hash_key"
EASYPAISA_BASE_URL="https://easypay-stg.easypaisa.com.pk/easypay/Index.jsf"
EASYPAISA_RETURN_URL="http://localhost:3000/payments/callback/easypaisa"

JAZZCASH_MERCHANT_ID="MC12345"
JAZZCASH_PASSWORD="pass123"
JAZZCASH_INTEGRITY_SALT="salt123"
JAZZCASH_BASE_URL="https://sandbox.jazzcash.com.pk/CustomerPortal/transaction/Checkout"
JAZZCASH_RETURN_URL="http://localhost:3000/payments/callback/jazzcash"

# Comma-separated browser origins (the page URL, not the API URL). When set, the API
# whitelists these plus built-in Velay / Vellay origins. PATCH/PUT/POST trigger a
# preflight OPTIONS; if your dashboard origin is missing here, the browser reports a
# CORS error even when GET works. Also allow any *.vercel.app preview unless disabled below.
# CORS_ORIGINS=https://your-dashboard.example.com,http://localhost:5173
# CORS_ALLOW_VERCEL_PREVIEWS=false

# --- Google Gemini (optional): improves POST /bookings/parse-free-text + staff summary ---
# Get a key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
#
# If you set GEMINI_API_KEY, either omit GEMINI_BOOKING_MODEL (uses built-in default) or set a model
# your key can call. List allowed names (use the "name" field without the "models/" prefix):
#   https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_GEMINI_API_KEY
# Common ids: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-flash-latest
# Wrong id → HTTP 404 warning in parse response; rules-only parsing still works.
# GEMINI_BOOKING_MODEL=gemini-2.5-flash
#
# Free tier has low RPM/TPD; HTTP 429 means quota — upgrade billing or unset GEMINI_API_KEY to use rules-only parse.

# --- OpenAI (optional): when OPENAI_API_KEY is set, it is used for POST /bookings/parse-free-text instead of Gemini.
# OPENAI_API_KEY=
# OPENAI_BOOKING_MODEL=gpt-4o-mini

# --- WhatsApp Cloud API ---
# Platform (one Meta app for all tenants). Per-business phone_number_id + access_token are saved via
# dashboard Settings → WhatsApp or POST /whatsapp/channels — NOT in this file.
#
# 1. Meta Developer → your app → WhatsApp → Configuration
# 2. Callback URL: https://YOUR_API_HOST/webhooks/whatsapp
# 3. Verify token: same as WHATSAPP_WEBHOOK_VERIFY_TOKEN below
# 4. Subscribe to "messages" field
#
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# WHATSAPP_GRAPH_API_VERSION=v21.0

# --- OpenWA (https://github.com/rmyndharis/OpenWA) ---
# Local OpenWA + production API: webhook URL must be your public API (below).
# Set the same OPENWA_* values on Vercel (Project → Settings → Environment Variables).
#
OPENWA_BASE_URL=http://localhost:2785
OPENWA_API_KEY=
OPENWA_WEBHOOK_SECRET=change-me-openwa-webhook-secret
OPENWA_WORKER_KEY=dev-openwa-worker
API_PUBLIC_URL=https://booking-saas-api-lilac.vercel.app
# Expose local OpenWA to the internet (ngrok/cloudflared) and set OPENWA_BASE_URL on Vercel to that URL so bot replies work.
